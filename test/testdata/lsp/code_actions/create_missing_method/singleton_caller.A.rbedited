# typed: true
# selective-apply-code-action: refactor
# enable-experimental-lsp-create-missing-method: true

class MyClass
  extend T::Sig

  sig { void }
  def self.caller
    do_class_thing("hello", 42)
#   ^^^^^^^^^^^^^^ error: Method `do_class_thing` does not exist on `T.class_of(MyClass)`
#     ^ apply-code-action: [A] Create missing method
  end

  sig { void }
  def self.other_method
  end

  sig { params(param: String, param1: Integer).returns(T.untyped) }
  def self.do_class_thing(param, param1)
    Kernel.raise NotImplementedError
  end
end
