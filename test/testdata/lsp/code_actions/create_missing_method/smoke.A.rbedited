# selective-apply-code-action: refactor
# enable-experimental-lsp-create-missing-method: true
# TODO(bshu): incorrect behavior

module Testing
  extend T::Sig
  extend T::Generic

  sig do
    type_parameters(:T)
      .params(x: String, y: Integer, t: T.type_parameter(:T))
      .void
  end
  def hello(x, y, t)
      create_me!(true, "1234234", 1, x, x, y, t, hello: 1243234)
#     ^^^^^^^^^^ error: Method `create_me!` does not exist on `Testing`
#       ^ apply-code-action: [A] Create missing method
  end

  sig { T.type_parameters(:T).params(param: T::Boolean, param1: String, param2: Integer, x: String, x1: String, y: Integer, t: T.type_parameter(:T), hello: Integer).returns(T.untyped) }
  def create_me!(param, param1, param2, x, x1, y, t, hello:)
    Kernel.raise NotImplementedError
  end
end
