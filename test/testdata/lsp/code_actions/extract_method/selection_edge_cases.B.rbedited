# typed: true
# selective-apply-code-action: refactor.extract
# enable-experimental-lsp-extract-to-method: true

class SelectionEdgeCases
  extend T::Sig

  sig {void}
  def while_body_statement
    x = T.let(0, Integer)
    sum = T.let(0, Integer)
    while x < 10
      sum = sum + x
#     ^^^^^^^^^^^^^ apply-code-action: [A] Extract Method
      x = x + 1
    end
    puts sum
  end

  sig {void}
  def multiple_params
    a = 1
    b = 2
    c = 3
    result = new_method(a, b, c)
#            ^^^^^^^^^ apply-code-action: [B] Extract Method
    puts result
  end

  sig { params(a: T.untyped, b: T.untyped, c: T.untyped).returns(T.untyped) }
  def new_method(a, b, c)
    a + b + c
  end


  sig {void}
  def no_live_out_internal_var
    x = 1
    y = x + 1; puts y
#   ^^^^^^^^^^^^^^^^^ apply-code-action: [C] Extract Method
    puts "done"
  end

  sig {void}
  def inside_rescue_body
    x = T.let(0, Integer)
    begin
      x = 42; puts "trying"
#     ^^^^^^^^^^^^^^^^^^^^^ apply-code-action: [D] Extract Method
    rescue
      puts "error"
    end
    puts x
  end

  sig {params(n: Integer).returns(Integer)}
  def helper(n)
    n * 2
  end

  sig {params(x: Integer).void}
  def uses_self_method(x)
    y = helper(x)
    puts y
#   ^^^^^^ apply-code-action: [E] Extract Method
  end

end
