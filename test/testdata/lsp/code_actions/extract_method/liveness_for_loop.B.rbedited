# typed: true
# selective-apply-code-action: refactor.extract
# enable-experimental-lsp-extract-to-method: true

class LivenessForLoop
  extend T::Sig

  sig {void}
  def for_loop_side_effect
    i = T.let(0, Integer)
    for i in 1..10
      puts i
#     ^^^^^^ apply-code-action: [A] Extract Method
    end
    puts i
  end

  sig {void}
  def for_loop_accumulator
    sum = T.let(0, Integer)
    i = T.let(0, Integer)
    for i in 1..10
      return_value, sum = new_method(i, sum)
#     ^^^^^^^^^^^^^ apply-code-action: [B] Extract Method
    end
    puts sum
  end

  sig { params(i: T.untyped, sum: T.untyped).returns([T.untyped, T.untyped]) }
  def new_method(i, sum)
    newMethodReturnValue = begin
      sum = sum + i
    end
    [newMethodReturnValue, sum]
  end

end
