# typed: true
# selective-apply-code-action: refactor.extract
# enable-experimental-lsp-extract-to-method: true

class BlockControlFlow
  extend T::Sig

  sig {returns(T.untyped)}
  def break_with_value
    result = [1, 2, 3].each do |i|
      val = i * 2
      new_method(val)
#     ^^^^^^^^^ apply-code-action: [A] Extract Method
    end
    result
  end

  sig { params(val: T.untyped).returns(T.untyped) }
  def new_method(val)
    break val
  end


  sig {void}
  def next_with_condition
    [1, 2, 3, 4].each do |i|
      next if i.even?
#     ^^^^^^^^^^^^^^^ apply-code-action: [B] Extract Method
      puts i
    end
  end

  sig {void}
  def return_in_lambda
    lam = lambda do
      x = 5
      return x
#     ^^^^^^^^ apply-code-action: [C] Extract Method
    end
    _ = lam
  end

  sig {void}
  def return_in_proc
    pr = proc do
      x = 10
      return x
#     ^^^^^^^^ apply-code-action: [D] Extract Method
    end
    pr.call
  end
end
