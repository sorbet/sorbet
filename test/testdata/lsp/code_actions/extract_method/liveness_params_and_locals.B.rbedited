# typed: true
# selective-apply-code-action: refactor.extract
# enable-experimental-lsp-extract-to-method: true

class LivenessParamsAndLocals
  extend T::Sig

  sig {params(x: Integer, y: Integer).void}
  def reads_params_only(x, y)
    z = x + y; puts z
#   ^^^^^^^^^^^^^^^^^ apply-code-action: [A] Extract Method
  end

  sig {void}
  def reads_prior_local_writes_live_out
    x = 10
    y = new_method(x)
#   ^^^^^^^^^ apply-code-action: [B] Extract Method
    puts y
  end

  sig { params(x: T.untyped).returns(T.untyped) }
  def new_method(x)
    y = x * 2
    y
  end


  sig {params(multiplier: Integer).void}
  def reads_param_and_local(multiplier)
    base = 100
    result = base * multiplier
#   ^^^^^^^^^^^^^^^^^^^^^^^^^^ apply-code-action: [C] Extract Method
    puts result
  end

  sig {params(n: Integer).void}
  def mixed_live_and_dead(n)
    temp = n * 2; result = temp + 1; temp = 0
#   ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ apply-code-action: [D] Extract Method
    puts result
  end
end
