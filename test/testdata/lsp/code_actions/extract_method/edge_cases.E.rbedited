# typed: true
# selective-apply-code-action: refactor.extract
# enable-experimental-lsp-extract-to-method: true

class EdgeCases
  extend T::Sig

  sig {params(x: Integer).returns(Integer)}
  def return_value_needed(x)
    y = x + 1
    y * 2
#   ^^^^^ apply-code-action: [A] Extract Method
  end

  sig {params(x: Integer).returns(Integer)}
  def return_value_needed_with_live_out(x)
    y = T.let(0, Integer)
    y = x + 1
#   ^^^^^^^^^ apply-code-action: [B] Extract Method
    puts y
    y
  end

  sig {params(x: Integer).returns(Integer)}
  def return_value_last_multi(x)
    z = 10
    y = x + 1; y * z
#   ^^^^^^^^^^^^^^^^ apply-code-action: [C] Extract Method
  end

  sig {params(x: Integer).void}
  def expression_context_with_live_out(x)
    y = T.let(0, Integer)
    result = (y = x + 1; y * 2)
#            ^^^^^^^^^^^^^^^^^^ apply-code-action: [D] Extract Method
    puts y
    puts result
  end

  sig {params(n: Integer).returns(Integer)}
  def self.class_method_extract(n)
    x = n * 2
    self.new_method(x)
#   ^^^^^ apply-code-action: [E] Extract Method
  end

  sig { params(x: T.untyped).returns(T.untyped) }
  def self.new_method(x)
    x + 1
  end


  sig {params(a: Integer, b: Integer).returns(Integer)}
  def extract_entire_body(a, b)
    x = a + b; x * 2
#   ^^^^^^^^^^^^^^^^ apply-code-action: [F] Extract Method
  end

  sig {params(x: Integer).returns(Integer)}
  def single_expr_is_return(x)
    x + 42
#   ^^^^^^ apply-code-action: [G] Extract Method
  end
end
