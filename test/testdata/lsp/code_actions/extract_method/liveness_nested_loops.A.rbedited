# typed: true
# selective-apply-code-action: refactor.extract
# enable-experimental-lsp-extract-to-method: true

class LivenessNestedLoops
  extend T::Sig

  sig {void}
  def inner_loop_body
    total = T.let(0, Integer)
    i = T.let(0, Integer)
    while total < 100
      i = 0
      while i < 10
        return_value, i, total = new_method(i, total)
#       ^^^^^^^^^^^^^^^^^^^^^^^^^^^^ apply-code-action: [A] Extract Method
      end
    end
  end

  sig { params(i: T.untyped, total: T.untyped).returns([T.untyped, T.untyped, T.untyped]) }
  def new_method(i, total)
    newMethodReturnValue = begin
      total = total + 1; i = i + 1
    end
    [newMethodReturnValue, i, total]
  end


  sig {void}
  def outer_loop_side_effects
    x = T.let(0, Integer)
    while x < 10
      puts x
#     ^^^^^^ apply-code-action: [B] Extract Method
      x = x + 1
    end
  end
end
