# typed: true
# selective-apply-code-action: refactor.extract
# enable-experimental-lsp-extract-to-method: true

class LivenessBasic
  extend T::Sig

  sig {void}
  def variable_used_after
    y = T.let(0, Integer)
    y = new_method()
#   ^^^^^^^^^ apply-code-action: [A] Extract Method
    puts y
  end

  sig { params().returns(T.untyped) }
  def new_method()
    y = 5 + 1
    y
  end


  sig {void}
  def no_live_out_simple
    puts 1; puts 2
#   ^^^^^^^^^^^^^^ apply-code-action: [B] Extract Method
    puts "done"
  end

  sig {void}
  def two_vars_modified
    x = T.let(0, Integer)
    y = T.let(0, Integer)
    x = 3; y = 4
#   ^^^^^^^^^^^^ apply-code-action: [C] Extract Method
    puts x
    puts y
  end
end
