# typed: true
# selective-apply-code-action: refactor.extract
# enable-experimental-lsp-extract-to-method: true

class LivenessWhileBodyToCondition
  extend T::Sig

  sig {void}
  def body_writes_condition_reads
    x = 0
    while (y = x * 2; y < 100)
      x = x + 3
#     ^^^^^^^^^ apply-code-action: [A] Extract Method
    end
  end

  sig {void}
  def multi_var_body_to_condition
    a = 0; b = 1
    while (c = a + b; c < 50)
      a = b; b = c
#     ^^^^^^^^^^^^ apply-code-action: [B] Extract Method
    end
  end

  sig {void}
  def body_to_simple_condition
    x = 0
    while x < 10
      x = x + 1
#     ^^^^^^^^^ apply-code-action: [C] Extract Method
    end
  end

  sig {void}
  def body_live_to_condition_and_post
    x = 0
    while (y = x + 1; y < 10)
      return_value, x = new_method(x)
#     ^^^^^^^^^ apply-code-action: [D] Extract Method
    end
    puts x
  end

  sig { params(x: T.untyped).returns([T.untyped, T.untyped]) }
  def new_method(x)
    newMethodReturnValue = begin
      x = x + 2
    end
    [newMethodReturnValue, x]
  end

end
