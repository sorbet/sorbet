# typed: true
# selective-apply-code-action: refactor.extract
# enable-experimental-lsp-extract-to-method: true

class LivenessConditional
  extend T::Sig

  sig {params(flag: T::Boolean).void}
  def if_branch_assigns(flag)
    x = T.let(0, Integer)
    return_value, x = new_method(flag)
#   ^^^^^^^^^^^^^^^^^^ apply-code-action: [A] Extract Method
    puts x
  end

  sig { params(flag: T.untyped).returns([T.untyped, T.untyped]) }
  def new_method(flag)
    newMethodReturnValue = begin
      if flag; x = 1 end
    end
    [newMethodReturnValue, x]
  end

end
